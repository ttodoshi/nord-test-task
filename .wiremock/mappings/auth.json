{
  "request": {
    "method": "POST",
    "url": "/auth",
    "headers": {
      "Content-Type": {
        "contains": "application/x-www-form-urlencoded"
      },
      "Accept": {
        "contains": "application/json"
      }
    },
    "bodyPatterns": [
      {
        "matches": ".*token=.*"
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {}
  }
}